# 기본적으로 모든 파일과 폴더를 무시
*

# git으로 관리할 파일들만 예외 처리
!.bashrc
!.gitconfig
!.gitconfig-personal
!.gitignore
!.zimrc
!.zshrc
!.tool-versions

# SSH 설정 파일
!.ssh/
.ssh/*
!.ssh/config

# zsh 설정 디렉토리
!.zshrc.d/
.zshrc.d/*
!.zshrc.d/mise.sh
!.zshrc.d/zim.sh
!.zshrc.d/zoxide.sh
!.zshrc.d/ssh.sh
!.zshrc.d/zz-kube-ps1.sh
!.testcontainers.properties

# XDG config
!.config/
.config/*

# mise 설정
!.config/mise/
.config/mise/*
!.config/mise/config.toml

# ghostty 설정
!.config/ghostty/
.config/ghostty/*
!.config/ghostty/config
